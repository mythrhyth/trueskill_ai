# Environment Configuration

GEMINI_API_KEY is provided.
LLM_PROVIDER=auto

# OpenAI API Configuration
# If set, enables LLM-based skill extraction with OpenAI.
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-3.5-turbo

# Gemini Flash / Gemini 2.5 Flash Configuration
# If set, enables LLM-based extraction using Gemini.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Service Configuration
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000
SERVICE_ENV=development

# Logging Configuration
LOG_LEVEL=INFO

# Database Configuration 
# DATABASE_URL=postgresql://user:password@localhost/skill_extraction
# DATABASE_URL=mongodb://localhost/skill_extraction



# n8n Integration 
# N8N_API_URL=http://localhost:5678/api
# N8N_API_KEY=your-n8n-api-key

# Feature Flags
ENABLE_LLM_EXTRACTION=true
ENABLE_VALIDATION=true
ENABLE_SCORING=true
ENABLE_XAI=true

# Performance Settings
MAX_WORKERS=4
REQUEST_TIMEOUT=30
CACHE_TTL=3600
